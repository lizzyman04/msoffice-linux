#!/usr/bin/env bash
# Wrapper for Microsoft PowerPoint via Bottles

EXE="POWERPNT.EXE"

if [[ -n "$1" ]]; then
    WIN_PATH="Z:$(echo "$1" | sed 's|/|\\|g')"
    flatpak run --command=bottles-cli com.usebottles.bottles run -b msoffice -p "$EXE" -- "$WIN_PATH" 2>/dev/null
else
    flatpak run --command=bottles-cli com.usebottles.bottles run -b msoffice -p "$EXE" 2>/dev/null
fi
